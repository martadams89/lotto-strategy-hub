{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lotto-strategy-hub",
  "compatibility_date": "2026-05-31",
  "main": "worker/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}

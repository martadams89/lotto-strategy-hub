# Copy this file to `.env` (which is git-ignored) and fill in your values,
# or export these as environment variables. NEVER commit real credentials.

# ── Cloudflare credentials — use EITHER a scoped token (recommended) OR the
#    Global API Key. Create tokens at https://dash.cloudflare.com/profile/api-tokens
# Scoped API token:
#   enable-dnssec.sh       → Zone:DNSSEC:Edit + Zone:Zone:Read
#   deploy-agent-worker.sh → Account:Workers Scripts:Edit + Zone:Workers Routes:Edit + Zone:Zone:Read
CF_API_TOKEN=

# …or Global API Key (My Profile › API Tokens › Global API Key):
CF_API_EMAIL=
CF_API_KEY=

# ── Needed only by deploy-agent-worker.sh ──
# Account ID: Cloudflare dashboard › any domain › Overview › Account ID (right rail)
CF_ACCOUNT_ID=
# Worker script name (any stable name; the same one owns the routes)
CF_WORKER_NAME=agent-edge

# ── Default domains (space-separated). Optional — you can pass them as CLI args
#    instead. Example: CF_DOMAINS="example.com www.example.com"
CF_DOMAINS=
